{
  "name": "@rawkoon/shared",
  "version": "1.0.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./types": "./src/types/index.ts",
    "./utils": "./src/utils/index.ts",
    "./constants": "./src/constants/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\" \"*.{ts,js,json,md}\"",
    "formatCheck": "prettier --check \"src/**/*.{ts,tsx,js,json,md}\" \"*.{ts,js,json,md}\""
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "@tanstack/react-query": "^5.100.9"
  }
}
