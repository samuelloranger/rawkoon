# =============================================================================
# Rawkoon Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines marked [Required] must be set. Everything else has sensible defaults.

# -----------------------------------------------------------------------------
# Database [Required]
# -----------------------------------------------------------------------------
POSTGRES_DB=rawkoon
POSTGRES_USER=rawkoon
POSTGRES_PASSWORD=change-me
# Must match the credentials above. Use 'db' as hostname when running in Docker.
DATABASE_URL=postgresql://rawkoon:change-me@db:5432/rawkoon

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Option A: individual fields (used when REDIS_URL is not set)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-me
# Option B: full URL (takes precedence over individual fields)
# REDIS_URL=redis://:change-me@redis:6379/0

# -----------------------------------------------------------------------------
# Image Storage
# -----------------------------------------------------------------------------
# Directory where uploaded images (avatars, chore/recipe photos) are stored.
# Relative paths resolve from the API process cwd (apps/api in dev).
# In Docker, mount this path to a persistent volume.
IMAGE_STORAGE_DIR=./data/images

# -----------------------------------------------------------------------------
# App [Required]
# -----------------------------------------------------------------------------
SECRET_KEY=generate-a-random-secret-here
# Session signing secret for better-auth. Must be at least 32 random characters.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-a-random-secret-here
# WebAuthn / Passkey (optional — defaults derived from BASE_URL)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Rawkoon
WEBAUTHN_ORIGIN=http://localhost:3000
BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=production
TZ=America/New_York
LOG_LEVEL=DEBUG
API_PORT=3000

# -----------------------------------------------------------------------------
# Web Push Notifications (VAPID)
# -----------------------------------------------------------------------------
# Required for browser push notifications. Generate keys with:
#
#   bunx web-push generate-vapid-keys
#
# This outputs a public key and a private key. Paste them below.
# Then create a vapid_keys/ directory and save them there as well,
# or just set these environment variables.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:your-email@example.com

# -----------------------------------------------------------------------------
# TMDB / OMDB (Optional - media discovery)
# -----------------------------------------------------------------------------
# Get a free TMDB API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# Get a free OMDB API key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# -----------------------------------------------------------------------------
# GitHub Releases (Optional - app update/release notifications)
# -----------------------------------------------------------------------------
# Public repository used by the Settings > Releases panel.
# Production Docker builds inject this from GitHub Actions using github.repository.
GITHUB_RELEASES_REPO=samuelloranger/rawkoon

# MediaInfo path remapping when importing from Radarr/Sonarr: translate *arr-internal
# paths to the actual filesystem path. *arr apps often store paths like
# /data/Movies/... but in your container they may be mounted at /mnt/storage/Movies/...
# MEDIA_PATH_FROM=/data
# MEDIA_PATH_TO=/mnt/storage
